    "eu-ai-act",
    "compliance",
    "grc",
    "attestation",
    "ai-governance"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mima-ai/governance"
  },
  "homepage": "https://docs.mima.ai",
  "bugs": "https://github.com/mima-ai/governance/issues",
  "devDependencies": {
    "typescript": "^5.4.0"
  }
